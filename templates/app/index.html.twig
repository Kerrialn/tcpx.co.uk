{% extends 'base.html.twig' %}

{% block body %}
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col items-center">

            <div class="w-full md:w-8/12">
                <video class="w-full h-auto rounded-lg object-cover" autoplay muted>
                    <source src="{{ asset('images/intro.mp4') }}" type="video/mp4">
                    Your browser does not support the video tag.
                </video>
            </div>

            <div class="w-full md:w-8/12 mt-8">
                <figure class="max-w-screen-md mx-auto text-center mb-12">
                    <svg class="w-10 h-10 mx-auto mb-3 text-gray-400 dark:text-gray-600" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 18 14">
                        <path d="M6 0H2a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h4v1a3 3 0 0 1-3 3H2a1 1 0 0 0 0 2h1a5.006 5.006 0 0 0 5-5V2a2 2 0 0 0-2-2Zm10 0h-4a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h4v1a3 3 0 0 1-3 3h-1a1 1 0 0 0 0 2h1a5.006 5.006 0 0 0 5-5V2a2 2 0 0 0-2-2Z"/>
                    </svg>
                    <blockquote>
                        <p class="text-2xl italic font-medium text-gray-900 dark:text-white">
                            “Modernising isn’t a cost — it’s an investment that adds €X to your valuation and consolidates your exit strategy.”
                        </p>
                    </blockquote>
                </figure>

                <div class="p-8 text-center bg-gray-50 dark:bg-gray-800 rounded-lg shadow-md">
                    <h1 class="mb-4 text-4xl font-extrabold leading-none tracking-tight text-gray-900 dark:text-white md:text-5xl lg:text-4xl">
                        Complimentary Valuation Risk Check
                    </h1>
                    <p class="mb-6 text-lg font-normal text-gray-500 dark:text-gray-400 lg:text-xl sm:px-16 xl:px-48">
                        Not sure how exposed your legacy PHP system is? We’ll run an initial high-level diagnostic at no cost.
                        You’ll get a clear picture of technical risks and how they may impact your business valuation — before committing
                        to a full report or upgrade.
                    </p>
                    <a href="{{ path('contact') }}"
                       class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-center text-white bg-blue-700 rounded-lg hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">
                        Request free risk check
                    </a>
                </div>

                <div class="text-3xl font-bold mt-12 mb-6 text-gray-800 dark:text-white">What do our clients say?</div>

                <figure class="flex items-start mb-6">
                    <div class="mr-4">
                        <img class="w-12 h-12 rounded-full border-2 border-gray-300 dark:border-gray-600"
                             src="{{ asset('images/testimoals/dave.jpeg') }}" alt="David Nunn">
                    </div>
                    <div>
                        <blockquote class="text-lg font-semibold text-gray-800 dark:text-white">
                            <p>"I take this opportunity to thank you for the massive effort you have put into getting
                                our project off the ground."</p>
                        </blockquote>
                        <figcaption class="mt-2 text-sm text-gray-500 dark:text-gray-400 text-right">
                            <cite title="Source Title">David Nunn - Senior Product Owner - RWE Renewables</cite>
                        </figcaption>
                    </div>
                </figure>
                <hr class="h-px my-8 bg-gray-200 dark:bg-gray-700 border-0">

                <figure class="flex items-start mb-6">
                    <div class="mr-4">
                        <img class="w-12 h-12 rounded-full border-2 border-gray-300 dark:border-gray-600"
                             src="{{ asset('images/testimoals/chris.jpeg') }}" alt="Christopher Carus">
                    </div>
                    <div>
                        <blockquote class="text-lg font-semibold text-gray-800 dark:text-white">
                            <p>"Working with TCPX has been a phenomenal experience, so straight forward from the outset,
                                they demonstrated exceptional expertise and professionalism."</p>
                        </blockquote>
                        <figcaption class="mt-2 text-sm text-gray-500 dark:text-gray-400 text-right">
                            <cite title="Source Title">Christopher Carus - Co-Founder and CTO - Jut-so</cite>
                        </figcaption>
                    </div>
                </figure>
                <hr class="h-px my-8 bg-gray-200 dark:bg-gray-700 border-0">

                <figure class="flex items-start mb-6">
                    <div class="mr-4">
                        <img class="w-12 h-12 rounded-full border-2 border-gray-300 dark:border-gray-600"
                             src="https://placehold.co/300x300?text=RG" alt="Robert Grant">
                    </div>
                    <div>
                        <blockquote class="text-lg font-semibold text-gray-800 dark:text-white">
                            <p>"This was a game-changer for us. Not only streamlined our codebase but also significantly
                                reduced our development costs. Our software runs faster, and the stability improvements
                                have been remarkable."</p>
                        </blockquote>
                        <figcaption class="mt-2 text-sm text-gray-500 dark:text-gray-400 text-right">
                            <cite title="Source Title">Robert Grant - Director - Engiserve</cite>
                        </figcaption>
                    </div>
                </figure>
                <hr class="h-px my-8 bg-gray-200 dark:bg-gray-700 border-0">

                <figure class="flex items-start mb-6">
                    <div class="mr-4">
                        <img class="w-12 h-12 rounded-full border-2 border-gray-300 dark:border-gray-600"
                             src="{{ asset('images/testimoals/ryan.jpeg') }}" alt="Ryan Jones">
                    </div>
                    <div>
                        <blockquote class="text-lg font-semibold text-gray-800 dark:text-white">
                            <p>"I'll admit, I was skeptical about the reality of automated refactoring at first.
                                The idea of trusting an external with our codebase seemed risky.
                                However, my doubts were completely dispelled. They have transformed our
                                software."</p>
                        </blockquote>
                        <figcaption class="mt-2 text-sm text-gray-500 dark:text-gray-400 text-right">
                            <cite title="Source Title">Ryan Jones - Project Manager</cite>
                        </figcaption>
                    </div>
                </figure>
            </div>

            <div class="flex flex-wrap justify-center items-center mt-12 space-x-4 md:space-x-8">
                <hr class="w-full h-px my-8 bg-gray-200 dark:bg-gray-700 border-0">
                <div class="flex-shrink-0 w-24 sm:w-32 md:w-40">
                    <img class="w-full h-auto" src="{{ asset('images/assosiation/rwe-logo-300.png') }}" alt="RWE Logo">
                </div>
                <div class="flex-shrink-0 w-24 sm:w-32 md:w-40">
                    <img class="w-full h-auto" src="{{ asset('images/assosiation/vodafone-logo-300.png') }}" alt="Vodafone Logo">
                </div>
                <div class="flex-shrink-0 w-24 sm:w-32 md:w-40">
                    <img class="w-full h-auto" src="{{ asset('images/assosiation/rector-logo-300.png') }}" alt="Rector Logo">
                </div>
                <div class="flex-shrink-0 w-24 sm:w-32 md:w-40">
                    <img class="w-full h-auto" src="{{ asset('images/assosiation/townpoint-logo-300.png') }}" alt="Townpoint Logo">
                </div>
            </div>
        </div>
    </div>
{% endblock %}