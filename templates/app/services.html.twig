{% extends 'base.html.twig' %}

{% block title %}PHP Consultancy Services – Architecture, Rector Refactoring & DB Modernisation | TCPX{% endblock %}

{% block meta_description %}PHP consultancy services: systems architecture review, automated refactoring with Rector, database layer modernisation, and full legacy PHP upgrade engagements. Fixed-fee discovery from €5,000.{% endblock %}
{% block meta_keywords %}PHP consultancy services, PHP systems architecture review, Rector automated refactoring, database layer modernisation, legacy PHP upgrade service, PHP 8 migration service{% endblock %}

{% block og_title %}PHP Consultancy Services – TCPX{% endblock %}
{% block og_description %}Systems architecture, Rector-powered automated refactoring, and database modernisation. Fixed-fee discovery report from €5,000. Incremental execution at €120–€150/hr.{% endblock %}
{% block og_url %}https://tcpx.co.uk/services{% endblock %}
{% block twitter_title %}PHP Consultancy Services – TCPX{% endblock %}
{% block twitter_description %}Systems architecture, Rector-powered automated refactoring, and database modernisation. Fixed-fee discovery report from €5,000.{% endblock %}

{% block json_ld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "PHP Consultancy",
  "provider": {
    "@type": "Organization",
    "name": "TCPX",
    "url": "https://tcpx.co.uk"
  },
  "name": "PHP Systems Architecture & Automated Refactoring",
  "description": "Expert PHP consultancy covering systems architecture design, automated code refactoring with Rector, database layer modernisation, and full legacy PHP upgrade engagements.",
  "url": "https://tcpx.co.uk/services",
  "offers": [
    {
      "@type": "Offer",
      "name": "Valuation Recovery Report",
      "description": "Rapid paid discovery: automated and manual analysis, prioritised roadmap, and risk register tied to business value.",
      "priceRange": "€5,000–€8,000",
      "priceCurrency": "EUR"
    },
    {
      "@type": "Offer",
      "name": "Incremental Modernisation",
      "description": "Embedded execution in production-safe slices alongside your team. Start-one-finish-one discipline.",
      "priceRange": "€120–€150/hour",
      "priceCurrency": "EUR"
    }
  ]
}
</script>
{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-center">
            <div class="w-full md:w-8/12">

                <!-- Page title -->
