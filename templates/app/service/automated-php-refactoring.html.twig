{% block twitter_description %}Rector-powered automated PHP refactoring: PHP 8 upgrades, custom AST rules, and large-scale code transformations applied safely.{% endblock %}

{% block json_ld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
