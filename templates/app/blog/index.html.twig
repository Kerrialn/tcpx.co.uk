{% extends 'base.html.twig' %}

{% block title %}PHP Consultancy Blog – Architecture, Rector & Database Modernisation | TCPX{% endblock %}

{% block meta_description %}Articles on PHP systems architecture, automated refactoring with Rector, database layer modernisation, and practical PHP upgrade techniques from TCPX consultants.{% endblock %}
{% block meta_keywords %}PHP blog, PHP architecture articles, Rector PHP tutorial, PHP database refactoring guide, PHP upgrade tips, PHP consultancy blog{% endblock %}

{% block og_title %}PHP Consultancy Blog – TCPX{% endblock %}
{% block og_description %}Articles on PHP systems architecture, Rector-powered automated refactoring, and database layer modernisation from TCPX.{% endblock %}
{% block og_url %}https://tcpx.co.uk/blog{% endblock %}
{% block twitter_title %}PHP Consultancy Blog – TCPX{% endblock %}
{% block twitter_description %}PHP architecture, automated Rector refactoring, and database modernisation articles from TCPX consultants.{% endblock %}

{% block json_ld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "TCPX PHP Consultancy Blog",
  "description": "Articles on PHP systems architecture, automated refactoring with Rector, and database layer modernisation.",
  "url": "https://tcpx.co.uk/blog",
  "publisher": {
    "@type": "Organization",
    "name": "TCPX",
    "url": "https://tcpx.co.uk"
  }
}
</script>
{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 pb-20">
        <div class="flex justify-center">
            <div class="w-full md:w-8/12">

                <h1 class="text-4xl font-extrabold text-gray-900 dark:text-white mb-3">Blog</h1>
                <p class="text-lg text-gray-600 dark:text-gray-300 mb-10 border-b border-gray-200 dark:border-gray-700 pb-10">
                    Practical articles on PHP systems architecture, automated refactoring with Rector, and database layer modernisation.
                </p>

                <div class="flex flex-col gap-6">
                    {% for post in posts %}
                        <article class="rounded-2xl border border-gray-200 dark:border-gray-700 p-7 hover:border-blue-400 dark:hover:border-blue-500 hover:shadow-sm transition-all">
                            <div class="text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-3">{{ post.date }}</div>
                            <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-3 leading-snug">
                                <a href="{{ path('blog_post', {slug: post.slug}) }}" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                                    {{ post.title }}
                                </a>
                            </h2>
                            <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed mb-5">{{ post.excerpt }}</p>
                            <a href="{{ path('blog_post', {slug: post.slug}) }}"
                               class="inline-flex items-center gap-1 text-sm text-blue-600 dark:text-blue-400 font-semibold hover:underline">
                                Read article
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            </a>
                        </article>
                    {% else %}
                        <p class="text-gray-600 dark:text-gray-300">No articles yet.</p>
                    {% endfor %}
                </div>

            </div>
        </div>
    </div>
{% endblock %}
