<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <link rel="icon" href="{{ asset('images/logo-white.png') }}"/>
    <title>{% block title %}TCPX – PHP Systems Architecture & Automated Refactoring Consultancy{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>

    <meta name="description"
          content="{% block meta_description %}TCPX are PHP consultants specialising in systems architecture, automated refactoring with Rector, and database layer modernisation. We modernise legacy PHP codebases safely and incrementally.{% endblock %}">
    <meta name="keywords"
          content="{% block meta_keywords %}PHP systems architecture, automated PHP refactoring, Rector PHP, PHP consultancy, legacy PHP upgrade, PHP 8 upgrade, Symfony migration, database refactoring, DB layer modernisation, PHP architect{% endblock %}">
    <meta name="author" content="TCPX">

    <!-- Open Graph -->
    <meta property="og:title" content="{% block og_title %}TCPX – PHP Systems Architecture & Automated Refactoring{% endblock %}">
    <meta property="og:description"
          content="{% block og_description %}PHP consultants specialising in systems architecture, automated refactoring with Rector, and database layer modernisation for legacy codebases.{% endblock %}">
    <meta property="og:url" content="{% block og_url %}https://tcpx.co.uk/{% endblock %}">
    <meta property="og:type" content="website">
    <meta property="og:image" content="{{ asset('images/code-carousel.png') }}">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{% block twitter_title %}TCPX – PHP Systems Architecture & Automated Refactoring{% endblock %}">
    <meta name="twitter:description"
          content="{% block twitter_description %}PHP consultants specialising in systems architecture, automated refactoring with Rector, and database layer modernisation for legacy codebases.{% endblock %}">
    <meta name="twitter:image" content="{{ asset('images/code-carousel.png') }}">

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "TCPX",
      "url": "https://tcpx.co.uk",
      "logo": "https://tcpx.co.uk/images/logo-white.png",
      "description": "PHP consultancy specialising in systems architecture, automated refactoring with Rector, and database layer modernisation.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "3rd Floor Suite, 207 Regent Street",
        "addressLocality": "London",
        "postalCode": "W1B 3HH",
        "addressCountry": "GB"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+420608187548",
        "email": "info@tcpx.co.uk",
        "contactType": "customer service"
      }
    }
    </script>
    {% block json_ld %}{% endblock %}

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.10.0/styles/atom-one-dark.min.css">

    {% block stylesheets %}
        {# TailwindCSS and Flowbite are handled by AssetMapper and should be included in the CSS output. #}
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}
            {{ importmap('app') }}
        {% endblock %}

        <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.10.0/highlight.min.js"></script>
        <script>
            document.addEventListener('turbo:load', function () {
                document.querySelectorAll('.article-body pre code').forEach(function (el) {
                    hljs.highlightElement(el);
                });
            });
        </script>

        {% if app.environment == 'prod' %}
            <script async src="https://www.googletagmanager.com/gtag/js?id=G-HY1P5Z0CLJ"></script>
            <script>
                window.dataLayer = window.dataLayer || [];
                function gtag() { dataLayer.push(arguments); }
                gtag('js', new Date());
                gtag('config', 'G-HY1P5Z0CLJ');
            </script>
        {% endif %}
    {% endblock %}
</head>
<body class="bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-sans">

{{ include('partial/_navbar.html.twig') }}

<main class="min-h-screen">
    {% block body %}{% endblock %}
</main>

<footer class="p-4 text-center bg-gray-50 dark:bg-gray-800 text-sm text-gray-500 dark:text-gray-400">
    Copyright © {{ "now"|date("Y") }} tcpx.co.uk
</footer>

</body>
</html>
