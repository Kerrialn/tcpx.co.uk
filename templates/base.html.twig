<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <link rel="icon" href="{{ asset('images/logo-white.png') }}"/>
    <title>{% block title %}TCPX – Legacy PHP Migration & Valuation Recovery{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>

    <meta name="description"
          content="Legacy PHP erodes business valuation and blocks exit options. TCPX modernises your codebase safely and incrementally so you regain control of risk, roadmap and valuation. Every €1 invested in modernisation today can return multiples at exit.">
    <meta name="keywords"
          content="legacy PHP upgrade, PHP migration experts, PHP 8 upgrade, Symfony migration, Laravel migration, CodeIgniter to Symfony, Zend to Laminas, Drupal 7 migration, Magento 1 to 2 upgrade, database fixer, valuation recovery, technical due diligence">
    <meta name="author" content="TCPX">

    <!-- Open Graph -->
    <meta property="og:title" content="TCPX – Valuation Recovery through Legacy PHP Upgrades">
    <meta property="og:description"
          content="We help companies protect and grow business value by modernising legacy PHP systems: PHP version upgrades, framework migrations, database normalisation and view conversion.">
    <meta property="og:url" content="https://tcpx.co.uk/">
    <meta property="og:type" content="website">
    <meta property="og:image" content="{{ asset('images/code-carousel.png') }}">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="TCPX – Legacy PHP Upgrades for Business Valuation Recovery">
    <meta name="twitter:description"
          content="Legacy code kills business valuation. TCPX modernises PHP apps with a multi-layer approach – from DB to framework to views – so you can exit with confidence.">
    <meta name="twitter:image" content="{{ asset('images/code-carousel.png') }}">

    {% block stylesheets %}
        {# TailwindCSS and Flowbite are handled by AssetMapper and should be included in the CSS output. #}
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}
            {{ importmap('app') }}
        {% endblock %}

        {% if app.environment == 'prod' %}
            <script async src="https://www.googletagmanager.com/gtag/js?id=G-HY1P5Z0CLJ"></script>
            <script>
                window.dataLayer = window.dataLayer || [];
                function gtag() { dataLayer.push(arguments); }
                gtag('js', new Date());
                gtag('config', 'G-HY1P5Z0CLJ');
            </script>
        {% endif %}
    {% endblock %}
</head>
