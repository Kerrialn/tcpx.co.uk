<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <link rel="icon" href="{{ asset('images/logo.png') }}"/>
    <title>{% block title %}TCPX{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>

    <meta name="description"
          content="Upgrade your PHP applications with TCPX. We specialize in PHP version upgrades, framework migrations, and database transitions to ensure security, performance, and maintainability. Contact us today!">
    <meta name="keywords"
          content="PHP upgrade services, PHP migration experts, PHP version update, PHP version migration support, legacy PHP, Symfony upgrade, Laravel migration, PHP 8, PHP support, framework upgrade, PHP development">
    <meta name="author" content="TCPX">
    <meta property="og:title" content="PHP Upgrades & Migrations – TCPX">
    <meta property="og:description"
          content="Upgrade your PHP applications with our services. We ensure smooth transitions, better performance, and long-term maintainability.">
    <meta property="og:url" content="https://tcpx.co.uk/">
    <meta property="og:type" content="website">
    <meta property="og:image" content="{{ asset('images/code-carousel.png') }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="PHP Upgrades & Migrations – TCPX">
    <meta name="twitter:description"
          content="We specialize in PHP version upgrades and framework migrations to keep your applications secure and optimized.">
    <meta name="twitter:image" content="{{ asset('images/code-carousel.png') }}">

    {% block stylesheets %}
        {# TailwindCSS and Flowbite are handled by AssetMapper and should be included in the CSS output. #}
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}
            {{ importmap('app') }}
        {% endblock %}

        {% if app.environment == 'prod' %}
            <script async src="https://www.googletagmanager.com/gtag/js?id=G-HY1P5Z0CLJ"></script>
            <script>
                window.dataLayer = window.dataLayer || [];

                function gtag() {
                    dataLayer.push(arguments);
                }

                gtag('js', new Date());
                gtag('config', 'G-HY1P5Z0CLJ');
            </script>
        {% endif %}
    {% endblock %}
</head>
<body class="bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-sans">

{{ include('partial/_navbar.html.twig') }}

<main class="min-h-screen">
    {% block body %}{% endblock %}
</main>

<footer class="p-4 text-center bg-gray-50 dark:bg-gray-800 text-sm text-gray-500 dark:text-gray-400">
    Copyright © {{ "now"|date("Y") }} tcpx.co.uk
</footer>

</body>
</html>